###
# runtime-supervisor — environment
###

# Postgres
DATABASE_URL=postgresql+psycopg://aic:aic@localhost:5432/aic

# Evidence log
EVIDENCE_HMAC_SECRET=dev-hmac-secret-change-me

# Policies
POLICY_PATH=packages/policies/refund.base.v1.yaml
APP_ENV=dev

# Integration API auth (JWT HS256 per app)
REQUIRE_AUTH=false
ADMIN_BOOTSTRAP_TOKEN=
# Outbound webhook HMAC signing secret
WEBHOOK_SECRET=dev-webhook-secret-change-me

###
# Control-center (Next.js)
###
SUPERVISOR_API_URL=http://localhost:8000
# When REQUIRE_AUTH=true, paste these from the seed script output:
SUPERVISOR_APP_ID=
SUPERVISOR_SECRET=
NEXT_PUBLIC_SUPERVISOR_API_URL=http://localhost:8000
