# Production environment for docker-compose.prod.yml.
# Copiar a `.env.prod` y completar. NUNCA commitear `.env.prod`.
# Arrancar con: `docker compose --env-file .env.prod -f docker-compose.prod.yml up -d`.

# ─── Domains (required) ──────────────────────────────────────────────────────
# Caddy usa estas vars para matchear hosts y emitir certificados HTTPS.
# Configurar registros A apuntando a la IP del VPS ANTES de levantar.
API_DOMAIN=api.tudominio.com
APP_DOMAIN=app.tudominio.com

# ─── Secrets (required — generar con `openssl rand -hex 32`) ────────────────
# HMAC usado para firmar bundles de evidence log. Rotar significa perder
# capacidad de verificar bundles viejos — guardar en secret manager.
EVIDENCE_HMAC_SECRET=REPLACE_ME_WITH_openssl_rand_-hex_32

# Firmas de webhooks salientes + JWT de sesiones del UI.
WEBHOOK_SECRET=REPLACE_ME_WITH_openssl_rand_-hex_32

# Token admin para crear la primera integration + el primer user. Después
# se puede rotar o sacar vía ratelimit. Ver DEPLOY.md paso 5.
ADMIN_BOOTSTRAP_TOKEN=REPLACE_ME_WITH_openssl_rand_-hex_24

# ─── Postgres (required) ─────────────────────────────────────────────────────
# El volumen `supervisor_data` persiste la DB entre restarts.
POSTGRES_USER=supervisor
POSTGRES_PASSWORD=REPLACE_ME_WITH_openssl_rand_-hex_24
POSTGRES_DB=supervisor

# ─── Control-center → supervisor (se llenan después del primer boot) ────────
# El UI firma sus requests al supervisor con estas credenciales. Crear
# vía: POST /v1/integrations con X-Admin-Token: $ADMIN_BOOTSTRAP_TOKEN,
# scope=["*"], name="ui-server". Guardar id + shared_secret acá y
# redeploy del control-center.
UI_SUPERVISOR_APP_ID=
UI_SUPERVISOR_SECRET=
