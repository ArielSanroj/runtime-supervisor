{
  "name": "@runtime-supervisor/client",
  "version": "0.2.0",
  "description": "TypeScript client for runtime-supervisor — evaluate, review, and audit agent actions.",
  "license": "Apache-2.0",
  "author": "Ariel San Martín",
  "homepage": "https://github.com/ArielSanroj/runtime-supervisor",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArielSanroj/runtime-supervisor.git"
  },
  "keywords": ["ai-agents", "llm", "guardrails", "policy-engine", "runtime-supervisor"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "tsx examples/smoke.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
